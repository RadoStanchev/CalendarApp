@model MeetingEditViewModel
@{
    ViewData["Title"] = "Редакция на среща";
    var startValue = Model.StartTime?.ToString("yyyy-MM-ddTHH:mm");
    var statuses = new Dictionary<int, string>
    {
        { 0, "Чака отговор" },
        { 1, "Прието" },
        { 2, "Отказано" }
    };
}

<div class="meeting-form-page">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">Редактирайте срещата</h1>
            <p class="text-muted mb-0">Актуализирайте информацията и прегледайте отговорите на участниците.</p>
        </div>
        <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Назад към детайлите</a>
    </div>

    <form asp-action="Edit" method="post" class="meeting-form" data-meeting-form>
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="CreatedById" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-4">
            <div class="col-12 col-lg-6">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="StartTime" class="form-label"></label>
                            <input asp-for="StartTime" type="datetime-local" class="form-control" value="@startValue" />
                            <span asp-validation-for="StartTime" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Location" class="form-label">Място</label>
                            <input asp-for="Location" class="form-control" placeholder="Актуализирайте мястото" />
                            <span asp-validation-for="Location" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                                <label asp-for="CategoryId" class="form-label mb-0"></label>
                                <button type="button" class="btn btn-link btn-sm p-0" data-bs-toggle="modal" data-bs-target="#categoryModal">
                                    + Нова категория
                                </button>
                            </div>
                            <select asp-for="CategoryId" class="form-select" data-category-select>
                                @foreach (var category in Model.Categories)
                                {
                                    <option value="@category.Id" selected="@(Model.CategoryId == category.Id ? true : false)" data-color="@category.Color">@category.Name</option>
                                }
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                        </div>

                        <div class="mb-0">
                            <label asp-for="Description" class="form-label">Описание</label>
                            <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-6">
                <div class="card shadow-sm border-0 h-100" data-meeting-search-root data-search-url="@Url.Action("SearchContacts", new { })" data-show-status="true">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div>
                                <h2 class="h5 fw-semibold mb-0">Участници</h2>
                                <p class="text-muted small mb-0">Управлявайте присъствието и поканете още хора за секунди.</p>
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="input-group">
                                <span class="input-group-text">🔍</span>
                                <input type="search" class="form-control" placeholder="Търсене по име или имейл" data-meeting-search />
                            </div>
                            <div class="list-group mt-2 d-none" data-meeting-search-results></div>
                        </div>

                        <div>
                            <h3 class="h6 text-muted text-uppercase mb-2">Присъствие</h3>
                            <div class="selected-participants" data-meeting-selected data-empty-text="Все още няма поканени.">
                                @if (!Model.Participants.Any())
                                {
                                    <p class="text-muted small mb-0" data-meeting-empty>Все още няма поканени.</p>
                                }
                                @for (var i = 0; i < Model.Participants.Count; i++)
                                {
                                    var participant = Model.Participants[i];
                                    var isCreator = participant.ContactId == Model.CreatedById;
                                    <div class="border rounded p-3 mb-2" data-participant data-contact-id="@participant.ContactId" data-is-creator="@(isCreator.ToString().ToLowerInvariant())">
                                            <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
                                                <div>
                                                    <div class="fw-semibold">@participant.DisplayName @if (isCreator) { <span class="badge bg-primary ms-1">Организатор</span> }</div>
                                                    <div class="text-muted small">@participant.Email</div>
                                                </div>
                                                <div class="d-flex align-items-center gap-2">
                                                    <select class="form-select form-select-sm" data-status-select name="Participants[@i].StatusId">
                                                        @foreach (var status in statuses)
                                                        {
                                                            <option value="@status.Key" selected="@(participant.StatusId == status.Key)">@status.Value</option>
                                                        }
                                                    </select>
                                                    <button type="button" class="btn btn-sm btn-outline-danger" data-remove-participant @(isCreator ? "disabled" : string.Empty)>&times;</button>
                                                </div>
                                            </div>
                                        <input type="hidden" data-contact-input name="Participants[@i].ContactId" value="@participant.ContactId" />
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4 d-flex justify-content-end gap-2">
            <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Отказ</a>
            <button type="submit" class="btn btn-primary">Запази промените</button>
        </div>
    </form>
    @await Html.PartialAsync("_CategoryModal", new CategoryCreateInputModel())
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/meetings.js" asp-append-version="true"></script>
    <script>
        window.initMeetingParticipants && window.initMeetingParticipants({
            rootSelector: '[data-meeting-search-root]',
            showStatus: true
        });

        window.initCategoryModal && window.initCategoryModal({
            selectSelector: '[data-category-select]',
            modalSelector: '#categoryModal'
        });
    </script>
}
